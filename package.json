{
  "name": "godin-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:scoped": "bash scripts/check-scoped-db.sh",
    "check:no-mock-render": "bash scripts/check-no-mock-render.sh",
    "dev:api": "pnpm --filter @pokta-engine/engine-api dev",
    "dev:worker": "pnpm --filter @pokta-engine/worker dev",
    "db:generate": "pnpm --filter @pokta-engine/db db:generate",
    "db:migrate": "pnpm --filter @pokta-engine/db db:migrate",
    "db:push": "pnpm --filter @pokta-engine/db db:push"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitejs/plugin-react": "^4.3.0",
    "@types/node": "^22.10.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}

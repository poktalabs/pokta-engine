{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/engine-api/**",
      "packages/**",
      "integrations/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "turbo.json",
      "tsconfig.base.json",
      "railway.api.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @godin-engine/db db:migrate && pnpm --filter @godin-engine/engine-api db:seed",
    "startCommand": "pnpm --filter @godin-engine/engine-api start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}

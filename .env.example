# Engine's own Postgres (D-1). pg-boss + Drizzle both use this single URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/godin_engine

# engine-api
PORT=8787

# Consumer auth (D-4 / M1.5). Comma-separated service keys: "<consumer_id>:<key>".
# The consumer_id is KEPT and used to scope every /v1 request to that tenant.
# FAIL CLOSED: if a request carries no valid X-Service-Key and no valid Privy
# Bearer token, it is 401 (there is NO "unset = allow all" dev bypass anymore).
# Example: SERVICE_KEYS=godinez-studio:dev-key-a,mi-pase:dev-key-b
SERVICE_KEYS=

# Browser auth (M1.5). Server-side Privy verification of the Authorization: Bearer
# <jwt> header. PRIVY_APP_ID is the JWT audience; PRIVY_APP_SECRET authenticates the
# server SDK. Both required for Bearer auth to work.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional PEM (ES256 public key). When set, Privy verification is fully OFFLINE
# (no JWKS fetch). When absent, the SDK fetches Privy's JWKS for PRIVY_APP_ID.
PRIVY_VERIFICATION_KEY=
# Optional map of verified Privy DID -> tenant id: "did:privy:xxx=mi-pase,did:privy:yyy=other".
# A principal that maps to no tenant still authenticates but is rejected by the
# dispatch tenant-check (TENANT_UNKNOWN).
PRIVY_TENANT_MAP=

# Operator surfaces (M1.5 / T3). /demo /dashboard /console emit cross-tenant
# rollups and are gated by header X-Operator-Key === OPERATOR_KEY. FAIL CLOSED: if
# OPERATOR_KEY is unset, those surfaces return 404 (not served).
OPERATOR_KEY=

# Integrations (read by the WORKER at module load — redeploy worker after changes).
# F1 Notion CRM (TASK-001): proposal-step writes the approved CRM row here.
NOTION_API_KEY=
NOTION_CRM_DB_ID=
# F2 Resend (TASK-002): send-step delivers the approved email via Resend.
RESEND_API_KEY=
RESEND_FROM=
# Optional demo-safety recipient override; defaults to the drafted email.to.
RESEND_TO=

# ---------------------------------------------------------------------------
# Mi Pase daily-pricing chain (M1 — pricing-draft → pricing-apply-confident /
# pricing-apply-flagged). Read by the WORKER's per-tenant resolver, keyed by the
# consumer's env prefix (mi-pase → MIPASE_*); see worker/src/provider-config.ts.
# Asking for one provider never reads the other's vars (narrow blast radius, D2).
# DEV STORE ONLY in M1 (D9) — point MIPASE_SHOPIFY_BASE_URL at the dev store.
# ---------------------------------------------------------------------------
# Shopify Admin API (dev store). baseUrl includes the /admin/api/<ver> path, e.g.
#   https://mi-pase-dev.myshopify.com/admin/api/2024-04
MIPASE_SHOPIFY_BASE_URL=
MIPASE_SHOPIFY_ACCESS_TOKEN=
# Mercado Libre MX catalog. ACCESS_TOKEN is required; the rest enable the
# 401 -> refresh -> retry-once path (optional — absent means no refresh, fail-soft).
MIPASE_ML_ACCESS_TOKEN=
MIPASE_ML_REFRESH_TOKEN=
MIPASE_ML_CLIENT_ID=
MIPASE_ML_CLIENT_SECRET=
MIPASE_ML_REDIRECT_URI=

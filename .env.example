# Engine's own Postgres (D-1). pg-boss + Drizzle both use this single URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/godin_engine

# engine-api
PORT=8787

# Consumer auth (D-4). Comma-separated service keys: "<consumer_id>:<key>".
# If unset, the API runs in DEV mode and accepts any request (logs a warning).
# Example: SERVICE_KEYS=godinez-studio:dev-key-a,landing-godinez:dev-key-b
SERVICE_KEYS=

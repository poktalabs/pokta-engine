# Engine's own Postgres (D-1). pg-boss + Drizzle both use this single URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/godin_engine

# engine-api
PORT=8787

# Consumer auth (D-4). Comma-separated service keys: "<consumer_id>:<key>".
# If unset, the API runs in DEV mode and accepts any request (logs a warning).
# Example: SERVICE_KEYS=godinez-studio:dev-key-a,landing-godinez:dev-key-b
SERVICE_KEYS=

# Privy auth (PR1 — Tier-1 security rails). engine-api verifies the SPA user's
# Privy JWT SERVER-SIDE and resolves it to a consumer/identity (the browser path;
# X-Service-Key stays the machine path). APP_SECRET is a SERVER secret — it must
# live here (engine-api / the worker if it verifies), NEVER in web/ (the browser
# only gets the public VITE_PRIVY_APP_ID). Set both on Railway engine-api too.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional: pin the verification key to avoid a network fetch on each verify.
# PRIVY_VERIFICATION_KEY=

# Integrations (read by the WORKER at module load — redeploy worker after changes).
# F1 Notion CRM (TASK-001): proposal-step writes the approved CRM row here.
NOTION_API_KEY=
NOTION_CRM_DB_ID=
# F2 Resend (TASK-002): send-step delivers the approved email via Resend.
RESEND_API_KEY=
RESEND_FROM=
# Optional demo-safety recipient override; defaults to the drafted email.to.
RESEND_TO=

# ---------------------------------------------------------------------------
# Mi Pase daily-pricing chain (M1 — pricing-draft → pricing-apply-confident /
# pricing-apply-flagged). Read by the WORKER's per-tenant resolver, keyed by the
# consumer's env prefix (mi-pase → MIPASE_*); see worker/src/provider-config.ts.
# Asking for one provider never reads the other's vars (narrow blast radius, D2).
# DEV STORE ONLY in M1 (D9) — point MIPASE_SHOPIFY_BASE_URL at the dev store.
# ---------------------------------------------------------------------------
# Shopify Admin API (dev store). baseUrl includes the /admin/api/<ver> path, e.g.
#   https://mi-pase-dev.myshopify.com/admin/api/2024-04
MIPASE_SHOPIFY_BASE_URL=
MIPASE_SHOPIFY_ACCESS_TOKEN=
# Mercado Libre MX catalog. ACCESS_TOKEN is required; the rest enable the
# 401 -> refresh -> retry-once path (optional — absent means no refresh, fail-soft).
MIPASE_ML_ACCESS_TOKEN=
MIPASE_ML_REFRESH_TOKEN=
MIPASE_ML_CLIENT_ID=
MIPASE_ML_CLIENT_SECRET=
MIPASE_ML_REDIRECT_URI=

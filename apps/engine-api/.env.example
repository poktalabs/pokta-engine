# ─────────────────────────────────────────────────────────────────────────────
# apps/engine-api — the Hono control-plane API (/v1 + operator surfaces).
# Local dev loads apps/engine-api/.env.local automatically (dev script
# --env-file-if-exists). On Railway, set these on the engine-api service.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres (shared with the worker). On Railway, reference the DB service:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/godin_engine

# HTTP port. Railway injects PORT automatically; code falls back to 8787.
PORT=8787

# Browser CORS for the /v1 data plane. Comma-separated EXACT origins allowed to call
# the engine from a browser (the SPA). The prod SPA is a different origin, so without
# this the browser blocks the Privy login before it reaches /v1/tenants/me. Fail-closed:
# unset/empty = no browser origin allowed (curl/server-to-server unaffected). Use the
# web service's exact origin (scheme + host, no trailing slash).
#   CORS_ORIGINS=https://godin-engineweb-production.up.railway.app
CORS_ORIGINS=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Machine callers (server-to-server). Comma-separated "consumer:key" pairs.
# Leave EMPTY if no machine caller exists — the browser/Privy path is unaffected.
SERVICE_KEYS=

# Privy (browser/SPA auth). APP_ID is the JWT audience; APP_ID here MUST equal the
# web app's VITE_PRIVY_APP_ID. APP_SECRET is server-only — never ships to the browser.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Legacy deploy seam (PR1). Maps a verified Privy DID to a tenant. PR2+ resolves the
# tenant ONLY from engine_tenants.members[]; this map is no longer a scope key — the
# route layer asserts-agrees-or-rejects it against the membership-resolved tenant
# (PR2b B1(b)). Prefer the per-tenant *_MEMBER_DIDS below. Leave unset in new deploys.
#   PRIVY_TENANT_MAP=did:privy:xxxx=mi-pase,did:privy:yyyy=vino
PRIVY_TENANT_MAP=
# Per-tenant member DIDs (PR2b B1), ADDITIVE — seedTenants unions these into
# engine_tenants.members[] (dedupe, never wipes; unset = no-op). The env var name is
# `${secretPrefix}_MEMBER_DIDS` (mi-pase's prefix is MIPASE, vino's is VINO). These
# are ops-owned secrets — NEVER commit real DIDs; placeholders only here.
#   MIPASE_MEMBER_DIDS=did:privy:xxxx,did:privy:yyyy
#   VINO_MEMBER_DIDS=did:privy:zzzz
MIPASE_MEMBER_DIDS=
VINO_MEMBER_DIDS=
# Optional: a PEM to verify Privy JWTs fully offline (no JWKS fetch). Omit to use JWKS.
PRIVY_VERIFICATION_KEY=

# Operator gate for the legacy cross-tenant HTML surfaces (/demo, /dashboard, /console).
# Leave EMPTY to keep those surfaces dark (they 404). Not needed for the SPA.
OPERATOR_KEY=

# ── Legacy demo/console display (OPTIONAL) ───────────────────────────────────
# Only the operator-gated /demo and /console pages read these, to render integration
# "configured?" status. The real integration side effects run in the WORKER, not here.
# Leave unset unless you use those legacy pages.
# NOTION_API_KEY=
# NOTION_CRM_DB_ID=
# RESEND_API_KEY=
# RESEND_FROM=
# LLM_MODEL=

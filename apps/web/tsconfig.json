{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // App needs the DOM libs the server base (ES2022 only) deliberately omits.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    // Drop the base `["node"]` global types; the SPA wants Vite's client ambient
    // types (import.meta.env, ?url imports) instead of Node globals. The test
    // harness (src/test/**) adds vitest globals + jest-dom matcher augmentation.
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "strict": true,
    "noEmit": true,
    // Bundler resolution handles `@pokta-engine/contract` from its ./src and the
    // `@/*` alias below — NO composite, NO project references (the repo is
    // source-only / noEmit everywhere; see M2 plan P0 sub-decision #1).
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}

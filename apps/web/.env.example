# @pokta-engine/web — local env (Vite, build-time)
#
# Mock-data-first: with mocks ON, apiFetch serves from the in-process registry
# and never touches the network. This is the default local dev mode for M2.
VITE_USE_MOCKS=true

# Engine API base URL. Only used when VITE_USE_MOCKS is NOT "true".
# In dev, the Vite proxy forwards /v1 → http://localhost:8787 (see vite.config.ts),
# so you can leave this empty and rely on the proxy.
VITE_API_URL=

# Privy app id (P6 auth). Leave empty for mock-only local dev.
VITE_PRIVY_APP_ID=

# Sentry DSN (P8). Leave empty locally.
VITE_SENTRY_DSN=

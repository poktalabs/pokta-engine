# ─────────────────────────────────────────────────────────────────────────────
# apps/worker — the job runner. Executes workflow run()s and their real side
# effects (CRM writes, emails, price updates), so the integration secrets live HERE.
# Local dev loads apps/worker/.env.local automatically. On Railway, set these on
# the worker service. (Integrations are read at module load — redeploy after changes.)
# ─────────────────────────────────────────────────────────────────────────────

# Postgres (shared with engine-api). On Railway: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/godin_engine

# Set to "off" to disable the autostart job loop (default: on).
WORKER_AUTOSTART=

# ── Mi Pase pricing integrations (per-tenant MIPASE_ prefix) ──────────────────
# Unconfigured = the integration runs "simulated" (no-op), never fails.
MIPASE_SHOPIFY_BASE_URL=
MIPASE_SHOPIFY_ACCESS_TOKEN=
MIPASE_ML_ACCESS_TOKEN=
MIPASE_ML_REFRESH_TOKEN=
MIPASE_ML_CLIENT_ID=
MIPASE_ML_CLIENT_SECRET=
MIPASE_ML_REDIRECT_URI=

# ── Demo / Vino integrations (Notion CRM + Resend email) ─────────────────────
NOTION_API_KEY=
NOTION_CRM_DB_ID=
RESEND_API_KEY=
RESEND_FROM=
# Optional demo-safety recipient override; defaults to the drafted email.to.
RESEND_TO=

# ── LLM (proposal drafting etc.) ──────────────────────────────────────────────
LLM_BASE_URL=
NEBIUS_API_KEY=

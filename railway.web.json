{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @pokta-engine/web build",
    "watchPatterns": [
      "apps/web/**",
      "packages/contract/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "turbo.json",
      "tsconfig.base.json",
      "railway.web.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @pokta-engine/web start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
